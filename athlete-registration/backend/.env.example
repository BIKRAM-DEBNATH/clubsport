# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/athlete_registration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/athlete_registration

# JWT Configuration - Generate a strong secret for production
# Unix command: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials - Change these in production!
ADMIN_EMAIL=admin@sports.com
ADMIN_PASSWORD=Admin@123

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=2097152
MAX_FILES_PER_UPLOAD=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
